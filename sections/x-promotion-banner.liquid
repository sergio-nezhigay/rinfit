{{- 'x-promotion-banner.css' | asset_url | stylesheet_tag -}}

{%- style -%}
  {% if section.settings.show_on_mobile == false %}
    @media screen and (max-width:767px) {
      #shopify-section-{{ section.id }} {
        display: none;
      }
    }
  {% endif %}

  {% if section.settings.show_on_tablet == false %}
    @media screen and (min-width:767px) and (max-width: 1024px) {
      #shopify-section-{{ section.id }} {
        display: none;
      }
    }
  {% endif %}

  {% if section.settings.show_on_desktop == false %}
    @media screen and (min-width: 1024px) {
      #shopify-section-{{ section.id }} {
        display: none;
      }
    }
  {% endif %}

  #shopify-section-{{ section.id }} {
    margin-block-start: {{ section.settings.padding_top }}px;
    margin-block-end: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div
  class="color-scheme color-scheme--{{ section.settings.color_scheme.id }} section-style--{{ section.settings.section_style }}"
>
  <div class="container">
    <div class="promotion-banner__media-wrapper">
      {% for block in section.blocks %}
        {% unless block.settings.image == blank %}
          {{ block.settings.image | image_url: height: '366' | image_tag: loading: 'lazy' }}
        {% endunless %}
      {% endfor %}
    </div>

    <div class="promotion-banner__content-wrapper">
      {%- render 'section-header',
        subheading: section.settings.subheading,
        heading: section.settings.title,
        content: section.settings.content
      -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "X: Promotion banner",
  "class": "shopify-section--promotion-banner",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_style",
      "label": "Style",
      "options": [
        {
          "value": "style_1",
          "label": "Style 1"
        },
        {
          "value": "style_2",
          "label": "Style 2"
        }
      ],
      "default": "style_1"
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_tablet",
      "label": "Show on tablet",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "separate_section_with_border",
      "label": "t:global.section.separate_section_with_border",
      "default": true
    },
    {
      "type": "header",
      "content": "t:global.section.header_category"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "t:global.text.subheading"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:global.text.heading",
      "default": "Limited-time offer"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "t:global.text.content"
    },

    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "X: Promotion banner",
      "category": "t:global.categories.banners"
    }
  ]
}
{% endschema %}
